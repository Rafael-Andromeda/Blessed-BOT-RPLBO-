<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.rplbo.app.rplboblessedbot.WelcomeController"
      prefWidth="500" prefHeight="400"
      alignment="CENTER" spacing="32"
      stylesheets="@blessbot.css"
      style="-fx-background-color:#FFF8EE;">

    <padding><Insets top="48" right="48" bottom="48" left="48"/></padding>

    <!-- Logo & Judul -->
    <VBox alignment="CENTER" spacing="10">
        <Label text="🤖" style="-fx-font-size:56px;"/>
        <Label text="BlessBot" styleClass="sidebar-logo-text"
               style="-fx-font-size:28px;"/>
        <Label text="Kedai Kopi Blessed"
               styleClass="label-muted"
               style="-fx-font-size:14px;"/>
    </VBox>

    <!-- Deskripsi -->
    <Label text="Selamat datang! Silakan pilih cara masuk."
           styleClass="label-body"
           style="-fx-font-size:14px;"
           wrapText="true" textAlignment="CENTER"/>

    <!-- Tombol pilihan -->
    <VBox spacing="14" alignment="CENTER" maxWidth="280">

        <!-- Masuk sebagai User -->
        <Button text="💬  Masuk sebagai User"
                styleClass="btn-primary"
                maxWidth="Infinity"
                prefHeight="46"
                style="-fx-font-size:14px;"
                onAction="#onMasukUser"/>

        <!-- Masuk sebagai Admin -->
        <Button text="🔐  Masuk sebagai Admin"
                styleClass="btn-secondary"
                maxWidth="Infinity"
                prefHeight="46"
                style="-fx-font-size:14px;"
                onAction="#onMasukAdmin"/>

    </VBox>

</VBox>
