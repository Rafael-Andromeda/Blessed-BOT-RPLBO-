<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.rplbo.app.rplboblessedbot.LokasiController"
      prefWidth="900" prefHeight="620"
      stylesheets="@blessbot.css">

    <!-- ===== SIDEBAR ===== -->
    <VBox styleClass="sidebar" prefWidth="220" spacing="0">
        <padding><Insets top="24" right="16" bottom="24" left="16"/></padding>

        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="🤖" style="-fx-font-size:24px;"/>
            <Label text="BlessBot" styleClass="sidebar-logo-text"/>
        </HBox>
        <Region prefHeight="32"/>

        <Button text="🏠  Dashboard" styleClass="sidebar-nav-item"
                onAction="#onDashboard"/>
        <Region prefHeight="8"/>
        <Button text="☰  Edit Menu" styleClass="sidebar-nav-item"
                onAction="#onEditMenu"/>
        <Region prefHeight="8"/>
        <Button text="📍  Lokasi" styleClass="sidebar-nav-item-active"
                onAction="#onLokasi"/>
        <Region prefHeight="8"/>
        <Button text="⏻  Logout" styleClass="sidebar-nav-item"
                onAction="#onLogout"/>

        <Region VBox.vgrow="ALWAYS"/>
        <HBox styleClass="sidebar-user-box" spacing="10" alignment="CENTER_LEFT">
            <Label text="👤" style="-fx-font-size:20px;"/>
            <Label text="Admin" styleClass="sidebar-user-label"/>
        </HBox>
    </VBox>

    <!-- ===== MAIN CONTENT ===== -->
    <VBox VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS" styleClass="content-area" spacing="20">

        <!-- Top Bar -->
        <HBox styleClass="topbar" alignment="CENTER_LEFT">
            <Label text="Lokasi" styleClass="topbar-title" HBox.hgrow="ALWAYS"/>
            <Label text="👤" style="-fx-font-size:22px; -fx-text-fill:#5C3D2E;"/>
        </HBox>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane">
            <VBox spacing="16">

                <!-- Map Card -->
                <VBox styleClass="card-white" spacing="14">
                    <Label text="Peta Lokasi" styleClass="label-subtitle"
                           style="-fx-font-size:17px; -fx-font-weight:bold;"/>

                    <!-- Map Placeholder (replace with WebView / MapView) -->
                    <StackPane styleClass="map-placeholder" prefHeight="180">
                        <VBox alignment="CENTER" spacing="6">
                            <Label text="📍" style="-fx-font-size:36px;"/>
                            <Label text="Jl. Anggrek No.10, Jogja"
                                   styleClass="label-body"
                                   style="-fx-font-weight:bold;"/>
                            <Label text="Google Maps" styleClass="label-accent"/>
                        </VBox>
                    </StackPane>

                    <!-- Info Grid -->
                    <GridPane hgap="12" vgap="12">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                        </columnConstraints>

                        <!-- Alamat -->
                        <VBox styleClass="card" spacing="6"
                              GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="Alamat" styleClass="card-title"/>
                            <Label fx:id="lblAlamat" text="Jl. Anggrek No.10, Jogja"
                                   styleClass="card-value" wrapText="true"/>
                        </VBox>

                        <!-- Jam Operasional -->
                        <VBox styleClass="card" spacing="6"
                              GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Jam Operasional" styleClass="card-title"/>
                            <Label fx:id="lblJam" text="08:00 – 22:00"
                                   styleClass="card-value"
                                   style="-fx-font-size:18px;"/>
                            <Label fx:id="lblHari" text="Setiap hari"
                                   styleClass="card-muted"/>
                        </VBox>

                        <!-- Patokan -->
                        <VBox styleClass="card" spacing="6"
                              GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="Patokan" styleClass="card-title"/>
                            <Label fx:id="lblPatokan"
                                   text="Dekat Malioboro, 500m dari Stasiun"
                                   styleClass="card-value" wrapText="true"/>
                        </VBox>

                        <!-- Parkir -->
                        <VBox styleClass="card" spacing="6"
                              GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label text="Parkir" styleClass="card-title"/>
                            <Label fx:id="lblParkir" text="Tersedia"
                                   styleClass="card-value"/>
                            <Label fx:id="lblParkirDetail" text="Motor &amp; Mobil"
                                   styleClass="card-muted"/>
                        </VBox>
                    </GridPane>
                </VBox>

            </VBox>
        </ScrollPane>
    </VBox>
</HBox>
