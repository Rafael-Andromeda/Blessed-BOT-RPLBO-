<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.rplbo.app.rplboblessedbot.DashboardAdminController"
      prefWidth="900" prefHeight="620"
      stylesheets="@blessbot.css">

    <!-- ===== SIDEBAR ===== -->
    <VBox styleClass="sidebar" prefWidth="220" spacing="0">
        <padding>
            <Insets top="24" right="16" bottom="24" left="16"/>
        </padding>

        <!-- Logo -->
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="🤖" style="-fx-font-size:24px;"/>
            <Label text="BlessBot" styleClass="sidebar-logo-text"/>
        </HBox>

        <Region prefHeight="32"/>

        <!-- Nav Items -->
        <Button text="🏠  Dashboard"
                styleClass="sidebar-nav-item-active"
                onAction="#onDashboard"/>

        <Region prefHeight="8"/>

        <Button text="☰  Edit Menu"
                styleClass="sidebar-nav-item"
                onAction="#onEditMenu"/>

        <Region prefHeight="8"/>

        <Button text="⭐  Rekomendasi Menu"
                styleClass="sidebar-nav-item"
                onAction="#onRekomendasiMenu"/>

        <Region prefHeight="8"/>

        <Button text="📍  Lokasi"
                styleClass="sidebar-nav-item"
                onAction="#onLokasi"/>

        <Region prefHeight="8"/>

        <Button text="⏻  Logout"
                styleClass="sidebar-nav-item"
                onAction="#onLogout"/>

        <Region VBox.vgrow="ALWAYS"/>

        <!-- User Box -->
        <HBox styleClass="sidebar-user-box" spacing="10" alignment="CENTER_LEFT">
            <Label text="👤" style="-fx-font-size:20px;"/>
            <Label text="Admin" styleClass="sidebar-user-label"/>
        </HBox>
    </VBox>

    <!-- ===== MAIN CONTENT ===== -->
    <VBox VBox.vgrow="ALWAYS"
          HBox.hgrow="ALWAYS"
          styleClass="content-area"
          spacing="20">

        <!-- Top Bar -->
        <HBox styleClass="topbar" alignment="CENTER_LEFT">
            <Label text="Dashboard"
                   styleClass="topbar-title"
                   HBox.hgrow="ALWAYS"/>

            <Label text="👤"
                   style="-fx-font-size:22px; -fx-text-fill:#5C3D2E;"/>
        </HBox>

        <ScrollPane fitToWidth="true"
                    VBox.vgrow="ALWAYS"
                    styleClass="scroll-pane">

            <VBox spacing="16" style="-fx-padding: 16 0 0 0;">

                <!-- Welcome -->
                <Label text="Selamat Datang Admin!"
                       styleClass="label-title"
                       style="-fx-font-size:22px;"/>

                <HBox spacing="16">

                    <!-- Left: Bot Card -->
                    <VBox HBox.hgrow="ALWAYS"
                          styleClass="card"
                          alignment="CENTER"
                          spacing="12"
                          prefHeight="180">

                        <Label text="🤖" style="-fx-font-size:64px;"/>

                        <Label text="BlessBot"
                               styleClass="sidebar-logo-text"
                               style="-fx-font-size:20px;"/>
                    </VBox>

                    <!-- Right: Login Activity -->
                    <VBox prefWidth="240" styleClass="card" spacing="10">
                        <Label text="Aktivitas Login Terakhir"
                               styleClass="card-title"/>

                        <Region styleClass="divider"/>

                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="🕐" style="-fx-font-size:16px;"/>
                            <Label fx:id="lblLogin1"
                                   text="Belum ada riwayat login"
                                   styleClass="login-status-label"
                                   wrapText="true"/>
                        </HBox>

                        <Region styleClass="divider"/>

                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="🕐" style="-fx-font-size:16px;"/>
                            <Label fx:id="lblLogin2"
                                   text="-"
                                   styleClass="login-status-label"
                                   wrapText="true"/>
                        </HBox>

                        <Region styleClass="divider"/>

                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="🕐" style="-fx-font-size:16px;"/>
                            <Label fx:id="lblLogin3"
                                   text="-"
                                   styleClass="login-status-label"
                                   wrapText="true"/>
                        </HBox>

                        <Region styleClass="divider"/>

                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="🕐" style="-fx-font-size:16px;"/>
                            <Label fx:id="lblLogin4"
                                   text="-"
                                   styleClass="login-status-label"
                                   wrapText="true"/>
                        </HBox>
                    </VBox>
                </HBox>

                <!-- Bottom Row: Manajemen Menu + Informasi Kedai -->
                <HBox spacing="16">

                    <!-- Manajemen Menu -->
                    <VBox styleClass="card" spacing="12" HBox.hgrow="ALWAYS" prefWidth="180" minWidth="160">
                        <Label text="Manajemen Menu" styleClass="card-title"/>

                        <Label fx:id="lblMenuCount"
                               text="Menu Terdaftar: 10"
                               styleClass="card-value"/>

                        <Region styleClass="divider"/>

                        <Button text="+ Tambah Menu"
                                styleClass="btn-primary"
                                maxWidth="Infinity"
                                onAction="#onTambahMenu"/>
                    </VBox>

                    <!-- Informasi Kedai -->
                    <VBox styleClass="card" spacing="10" HBox.hgrow="ALWAYS" prefWidth="340" minWidth="200">
                        <Label text="Informasi Kedai" styleClass="card-title"/>

                        <Label text="Jam Operasional" styleClass="card-value"/>

                        <Label fx:id="lblJamOps"
                               text="08:00 - 22:00"
                               styleClass="label-body"/>

                        <Region styleClass="divider"/>

                        <Label text="Alamat" styleClass="card-value"/>

                        <Label fx:id="lblAlamat"
                               text="Jl. Anggrek No.10 Jogja"
                               styleClass="label-body"/>

                        <Region styleClass="divider"/>
                    </VBox>
                </HBox>

                <!-- Card Rekomendasi Menu Mingguan -->
                <VBox styleClass="card" spacing="12">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="⭐  Rekomendasi Menu Mingguan"
                               styleClass="card-title"
                               HBox.hgrow="ALWAYS"
                               style="-fx-font-size:14px;"/>

                        <Button text="Kelola →"
                                styleClass="btn-secondary"
                                style="-fx-font-size:12px; -fx-padding:6 12 6 12;"
                                onAction="#onRekomendasiMenu"/>
                    </HBox>

                    <Region styleClass="divider"/>

                    <VBox fx:id="rekomendasiPreviewBox" spacing="8">
                        <Label text="Memuat data rekomendasi..."
                               styleClass="label-muted"/>
                    </VBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </VBox>
</HBox>