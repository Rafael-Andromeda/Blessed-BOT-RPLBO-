<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.rplbo.app.rplboblessedbot.ManajemenMenuController"
      prefWidth="900" prefHeight="620"
      stylesheets="@blessbot.css">

    <!-- ===== SIDEBAR ===== -->
    <VBox styleClass="sidebar" prefWidth="220" spacing="0">
        <padding>
            <Insets top="24" right="16" bottom="24" left="16"/>
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="🤖" style="-fx-font-size:24px;"/>
            <Label text="BlessBot" styleClass="sidebar-logo-text"/>
        </HBox>

        <Region prefHeight="32"/>

        <Button text="🏠  Dashboard"
                styleClass="sidebar-nav-item"
                onAction="#onDashboard"/>

        <Region prefHeight="8"/>

        <Button text="☰  Edit Menu"
                styleClass="sidebar-nav-item-active"
                onAction="#onEditMenu"/>

        <Region prefHeight="8"/>

        <Button text="⭐  Rekomendasi Menu"
                styleClass="sidebar-nav-item"
                onAction="#onRekomendasiMenu"/>

        <Region prefHeight="8"/>

        <Button text="📍  Lokasi"
                styleClass="sidebar-nav-item"
                onAction="#onLokasi"/>

        <Region prefHeight="8"/>

        <Button text="⏻  Logout"
                styleClass="sidebar-nav-item"
                onAction="#onLogout"/>

        <Region VBox.vgrow="ALWAYS"/>

        <HBox styleClass="sidebar-user-box" spacing="10" alignment="CENTER_LEFT">
            <Label text="👤" style="-fx-font-size:20px;"/>
            <Label text="Admin" styleClass="sidebar-user-label"/>
        </HBox>
    </VBox>

    <!-- ===== MAIN CONTENT ===== -->
    <VBox HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS" styleClass="content-area" spacing="20">

        <!-- Top Bar -->
        <HBox styleClass="topbar" alignment="CENTER_LEFT">
            <Label text="Manajemen Menu"
                   styleClass="topbar-title"
                   HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- Content Card -->
        <VBox styleClass="card-white" spacing="16" VBox.vgrow="ALWAYS">

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Daftar Menu"
                       styleClass="label-title"
                       HBox.hgrow="ALWAYS"/>

                <Button text="＋ Tambah Menu"
                        styleClass="btn-primary"
                        onAction="#onTambahMenu"/>
            </HBox>

            <TableView fx:id="menuTable"
                       styleClass="menu-table"
                       VBox.vgrow="ALWAYS">

                <columns>
                    <TableColumn fx:id="colFoto"
                                 text="Foto"
                                 prefWidth="90"/>

                    <TableColumn fx:id="colNama"
                                 text="Nama Menu"
                                 prefWidth="260"/>

                    <TableColumn fx:id="colHarga"
                                 text="Harga"
                                 prefWidth="160"/>

                    <TableColumn fx:id="colAksi"
                                 text="Aksi"
                                 prefWidth="160"/>
                </columns>

            </TableView>

        </VBox>
    </VBox>
</HBox>